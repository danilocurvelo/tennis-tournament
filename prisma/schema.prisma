// Prisma schema for Tennis Tournament

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id          Int      @id @default(autoincrement())
  name        String
  nationality String
  ranking     Int?

  matchesPlayer1 Match[] @relation("Player1Matches")
  matchesPlayer2 Match[] @relation("Player2Matches")
  matchesWon     Match[] @relation("MatchWinner")
}

model Tournament {
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  startDate DateTime
  endDate   DateTime

  matches   Match[]
}

model Match {
  id           Int       @id @default(autoincrement())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId Int

  player1   Player @relation("Player1Matches", fields: [player1Id], references: [id])
  player1Id Int
  player2   Player @relation("Player2Matches", fields: [player2Id], references: [id])
  player2Id Int
  winner    Player? @relation("MatchWinner", fields: [winnerId], references: [id])
  winnerId  Int?

  round Int
  score String?
}

